#include "postrcve.h"

SUB post:RCVEconsulta_mp

	IF (post:adt_tmp_codint_mp == "MPC" || post:adt_tmp_codint_mp == "MPD") THEN
		CALL post:RCVEhdr_mp_point
	ELSE
		CALL post:RCVEhdr_mp
	END	IF

	IF (hcomm:tran_status == HOST_ACCEPTED)
		CALL post:RCVEgral_mp
		IF (RETVAL < 0) THEN
			RETURN -2
		END IF
	ELSE
		RETURN -2
	END IF

	CALL post:MISCconsulta_mp
	IF (RETVAL < 0) THEN
		RETURN -2
	END IF

END SUB

