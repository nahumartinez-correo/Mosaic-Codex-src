/****o* Pendientes de agrupación/OFB:op:MISCmpVtaIncAT
* NOMBRE
*   OFB:op:MISCmpVtaIncAT
* DESCRIPCION
*   Verifica venta MP inconclusa y evalua at_terminal
* ENTRADAS
* SALIDAS
*   RETVAL: 0	->	No hay venta "at_terminal" en el Point
*   RETVAL: 1	->	Hay una venta "at_terminal" en el Point y lo esta bloqueando
* SOURCE
*/

#include "src\OP\misc\opmisc.h"

SUB op:MISCmpVtaIncAT
	LOCAL l_retval LIKE lib:err_retval
	LOCAL l_idx LIKE siaf:i
	LOCAL l_inf LIKE siaf:i

	// Solo se trabaja con terminales integradas
	CALL post:CDSsel_termi_mp
	IF (RETVAL != 0) THEN
		RETURN 0
	END IF

	#if CORREO_DEBUG == CORREO_ON
	DPRINT "[DBG] Verificacion venta inconclusa con status [at_terminal]\n"
	#endif

	// Se verifica si existe registro de un presupuesto activo del mismo dia para el operador
	CDS SELECT FROM DSC:post:TABPresuActi BECOMES DSC:post:CONPresuActi \
		WHERE post:op_operator_id == fld:op:op_operator_id \
		&& post:fecha == common:system_date
	CDS FINDFIRST DSC:post:CONPresuActi NOLOCK

	// Si existe, se toma el dato del ID de la orden que pudo quedar "at_terminal" en el Point
	IF (CDSRETVAL == 0) THEN
		IF (post:estado_presu != 1) THEN
			#if CORREO_DEBUG == CORREO_ON
			DPRINT "[DBG] El presupuesto esta iniciado. Se debe validar el status en el Point\n"
			#endif
			//			Tabla					Variable de la tabla			Variable en memoria
			CDS EXTRACT DSC:post:CONPresuActi	post:mp_recov_order_id 	INTO 	post:mp_order_id_PS
			//			Tabla					Variable de la tabla			Variable en memoria
			CDS EXTRACT DSC:post:CONPresuActi	post:PresNro 			INTO 	post:PresNro
		ELSE
			DPRINT "[DBG] El presupuesto no esta iniciado. Se retorna\n"
			RETURN 0
		ENDIF
	END IF
	CDS ENDSELECT DSC:post:CONPresuActi

	// Se verifica si existia una orden, para volver al flujo normal si no hay nada
	IF ( post:mp_order_id_PS.NUMCHARS == 0 )
		#if CORREO_DEBUG == CORREO_ON
		DPRINT "[DBG] La variable [mp_recov_order_id] esta vacia. Se retorna\n"
		#endif
		// Se indica que hay una orden "at_terminal" en el point para no dejar crear nuevas		
		RETURN 0
	ELSE
		#if CORREO_DEBUG == CORREO_ON
		DPRINT "[DBG] La variable [mp_recov_order_id] tiene el contenido %s\n" post:mp_order_id_PS
		#endif

		// Se recupera el contexto de la venta inconclusa sabiendo el numero del presupuesto
		CDS SELECT FROM DSC:post:OperacionesMP_tbl BECOMES DSC:post:OperacionesMP_ctx \
			WHERE post:adt_opmp_fecha == common:system_date \
			&& post:adt_opmp_termi_win == common:window_node \
			&& post:adt_opmp_login_id == op:op_login_id \
			&& post:adt_opmp_PresNro == post:PresNro

		// Se toma el primer registro, aunque sea unico
		CDS FINDFIRST DSC:post:OperacionesMP_ctx NOLOCK
		LET l_retval = CDSRETVAL
		IF (l_retval != 0) THEN

			DPRINT "[DBG] No se encontro ningun registro para ese presupuesto\n"

			CDS ENDSELECT DSC:post:OperacionesMP_ctx
			RETURN -2
		END IF

		DPRINT "[DBG] Se encontro el registro y se extraeran los valores\n"

		CDS EXTRACT DSC:post:OperacionesMP_ctx ALL
		CDS EXTRACT DSC:post:OperacionesMP_ctx \
		post:adt_opmp_fecha \
		post:adt_opmp_login_id \
		post:adt_opmp_termi_win \
		post:adt_opmp_operacion \
		post:adt_opmp_status_p_PS \
		post:adt_opmp_jnlOK 
		CDS ENDSELECT DSC:post:OperacionesMP_ctx

		// Se recupera el secuenciador
		LET post:adt_vpi_codseq_nro = post:adt_opmp_codseq_nro
		LET post:adt_mp_codseq_nro = post:adt_opmp_codseq_nro
		LET post:PresNro = post:adt_opmp_PresNro
		LET post:adt_tmp_device_name = post:adt_opmp_device_name
		LET post:adt_tmp_codint_mp = post:adt_opmp_codint_mp
		LET post:mp_comandos = post:adt_opmp_comandos
		LET post:mp_operacion = "VEN"

		RETURN 1
	ENDIF

	RETURN 0
END SUB

/******/
